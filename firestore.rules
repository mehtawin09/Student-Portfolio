rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is logged in
    function isLoggedIn() {
      return request.auth != null;
    }

    // Helper function to validate ID pattern (alphanumeric, dashes, underscores)
    function isValidId(id) {
      return id.size() > 0 && id.size() <= 100 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper function to validate Student Portfolio schema
    function isValidStudentPortfolio(data) {
      return data.keys().hasAll(['id', 'teacherUid', 'firstName', 'lastName', 'gender', 'currentGrade'])
        && data.id is string
        && data.teacherUid == request.auth.uid
        && data.firstName is string
        && data.firstName.size() > 0
        && data.firstName.size() <= 100
        && data.lastName is string
        && data.lastName.size() > 0
        && data.lastName.size() <= 100
        && data.gender in ['Male', 'Female']
        && data.currentGrade in [
          'Kindergarten 1', 'Kindergarten 2', 'Kindergarten 3',
          'Prathom 1', 'Prathom 2', 'Prathom 3',
          'Prathom 4', 'Prathom 5', 'Prathom 6'
        ];
    }

    match /students/{studentId} {
      allow read: if isLoggedIn() && (resource == null || resource.data.teacherUid == request.auth.uid);
      allow create: if isLoggedIn() && isValidId(studentId) && isValidStudentPortfolio(request.resource.data);
      allow update: if isLoggedIn() && isValidId(studentId) && resource.data.teacherUid == request.auth.uid && isValidStudentPortfolio(request.resource.data);
      allow delete: if isLoggedIn() && resource.data.teacherUid == request.auth.uid;
    }
  }
}
